# Public hostname and TLS
# Run ./setup.sh --domain chat.example.com to fill domain values and secrets automatically.
# Use --port to set a non-standard public port (for example behind a reverse proxy on :4443).
# FLUXER_PUBLIC_URL is derived automatically by setup.sh/upgrade.sh from the scheme, domain, and port.
FLUXER_DOMAIN=chat.example.com
FLUXER_PUBLIC_SCHEME=https
FLUXER_PUBLIC_PORT=443
FLUXER_PUBLIC_URL=https://chat.example.com
FLUXER_CADDY_SITE_ADDRESS=chat.example.com

# Header used to read the real client IP from the reverse proxy. Only change this
# if you replace the bundled Caddy proxy with one that sets a different header.
FLUXER_CLIENT_IP_HEADER_NAME=x-forwarded-for

# Container images (defaults pull from ghcr.io; set owner to Quad4-Software when using images built from this repo)
FLUXER_REGISTRY_OWNER=fluxerapp
FLUXER_REGISTRY=ghcr.io/${FLUXER_REGISTRY_OWNER}
FLUXER_IMAGE_TAG=v1

# Database and infrastructure secrets (generated by setup.sh)
POSTGRES_PASSWORD=CHANGE_ME
MEILI_MASTER_KEY=CHANGE_ME
FLUXER_S3_ACCESS_KEY=fluxer
FLUXER_S3_SECRET_KEY=CHANGE_ME

# Application secrets (generated by setup.sh)
FLUXER_SUDO_MODE_SECRET=CHANGE_ME
FLUXER_CONNECTION_INITIATION_SECRET=CHANGE_ME
FLUXER_GATEWAY_RPC_AUTH_TOKEN=CHANGE_ME
FLUXER_MEDIA_PROXY_SECRET_KEY=CHANGE_ME
FLUXER_MEDIA_PROXY_UPLOAD_RELAY_SECRET_BASE64=CHANGE_ME
FLUXER_ADMIN_SECRET_KEY_BASE=CHANGE_ME
FLUXER_ADMIN_OAUTH_CLIENT_SECRET=CHANGE_ME

# Web push (generated by setup.sh)
FLUXER_VAPID_PUBLIC_KEY=CHANGE_ME
FLUXER_VAPID_PRIVATE_KEY=CHANGE_ME
FLUXER_VAPID_EMAIL=admin@example.com

# LiveKit voice (key is fixed; secret is generated by setup.sh)
LIVEKIT_API_KEY=fluxer
LIVEKIT_API_SECRET=CHANGE_ME

# Optional integrations
FLUXER_KLIPY_API_KEY=

# Email (disabled by default; configure here or in the admin panel)
FLUXER_EMAIL_ENABLED=false
FLUXER_EMAIL_PROVIDER=none
FLUXER_EMAIL_FROM_EMAIL=noreply@example.com
FLUXER_EMAIL_FROM_NAME=Fluxer
FLUXER_EMAIL_SMTP_HOST=
FLUXER_EMAIL_SMTP_PORT=587
FLUXER_EMAIL_SMTP_USERNAME=
FLUXER_EMAIL_SMTP_PASSWORD=
FLUXER_EMAIL_SMTP_SECURE=true

# Captcha and discovery (ALTCHA is enabled by default; no third-party keys required)
FLUXER_CAPTCHA_ENABLED=true
FLUXER_CAPTCHA_PROVIDER=altcha
FLUXER_CAPTCHA_ALTCHA_HMAC_SECRET=CHANGE_ME
FLUXER_DISCOVERY_ENABLED=true

# Optional performance tuning (defaults are sensible for small-to-medium instances)
FLUXER_VALKEY_MAXMEMORY=512mb
FLUXER_MEILI_MAX_INDEXING_MEMORY=512Mb
FLUXER_MEILI_HTTP_PAYLOAD_SIZE_LIMIT=104857600

# Optional monitoring (Sentry or GlitchTip)
FLUXER_SENTRY_ENABLED=false
FLUXER_SENTRY_CLIENT_ENABLED=false
FLUXER_SENTRY_DSN=
FLUXER_SENTRY_ENVIRONMENT=

# Optional offline breached-password checks (easypwned / HIBP bloom filter)
# Enable with: ./setup.sh --easypwned --domain chat.example.com
# Start with: docker compose --profile easypwned up -d
FLUXER_EASYPWNED_ENABLED=false
FLUXER_EASYPWNED_URL=http://easypwned:3342
FLUXER_EASYPWNED_FAIL_OPEN=true

# Optional automatic container updates (fluxer-updater)
# Enable with: ./setup.sh --auto-update --domain chat.example.com
# Start with: docker compose --profile auto-update up -d
# Polls the registry for new images tagged with FLUXER_IMAGE_TAG and restarts
# labeled Fluxer services one at a time when a newer image is available.
# Infrastructure images pinned by digest in docker-compose.yml are not updated.
FLUXER_AUTO_UPDATE_ENABLED=false
FLUXER_AUTO_UPDATE_POLL_INTERVAL=86400

# Optional branding (also configurable in the admin panel)
# Leave status page URLs empty on self-hosted instances to hide SaaS status links.
FLUXER_APP_STATUS_PAGE_URL=
FLUXER_APP_STATUS_PAGE_INCIDENT_HISTORY_URL=
