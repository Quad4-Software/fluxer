#
# Copy to config/env/local.env for native-host development only (not Docker Compose dev).
# Inside the workspace container, development.env service hostnames (postgres, meilisearch, ...)
# are used automatically. Keeping this file while running `task compose:dev` breaks Meilisearch
# and other infra lookups.

FLUXER_POSTGRES_HOST=127.0.0.1
FLUXER_KV_URL=redis://127.0.0.1:6379/0
FLUXER_NATS_URL=nats://127.0.0.1:4222
FLUXER_NATS_JETSTREAM_URL=nats://127.0.0.1:4222
FLUXER_SVC_NATS_URL=nats://127.0.0.1:4222
FLUXER_SEARCH_URL=http://127.0.0.1:7700

VALKEY_HOST=127.0.0.1
NATS_HOST=127.0.0.1
LIVEKIT_HOST=127.0.0.1
MAILPIT_HOST=127.0.0.1
